<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="TOP_LEFT" xmlns:fx="http://javafx.com/fxml"
      fx:controller="ShoppingCartController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="%title"/>

    <ComboBox fx:id="languageComboBox" onAction="#handleChangeLanguage"/>

    <Label fx:id="itemsLabel" text="%prompt.items"/>
    <TextField fx:id="itemsField"/>

    <Label fx:id="priceLabel" text="%prompt.price"/>
    <TextField fx:id="priceField"/>

    <Label fx:id="qtyLabel" text="%prompt.qty"/>
    <TextField fx:id="qtyField"/>

    <Button text="%button.calculate" onAction="#handleCalculate"/>

    <Label fx:id="itemTotalLabel" text="%item.total"/>
    <Label fx:id="itemTotalResultLabel" text="0.0"/>

    <Label fx:id="totalLabel" text="%total"/>
    <Label fx:id="totalResultLabel" text="0.0"/>
</VBox>