<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox" spacing="10" alignment="TOP_LEFT" xmlns:fx="http://javafx.com/fxml"
      fx:controller="shoppingcartapp.ShoppingCartController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Shopping Cart"/>

    <ComboBox fx:id="languageComboBox" onAction="#handleChangeLanguage" prefWidth="160"/>

    <Label fx:id="itemsLabel" text="Item Number"/>
    <TextField fx:id="itemsField"/>

    <Label fx:id="priceLabel" text="Price"/>
    <TextField fx:id="priceField"/>

    <Label fx:id="qtyLabel" text="Quantity"/>
    <TextField fx:id="qtyField"/>

    <Button fx:id="calculateButton" text="Calculate" onAction="#handleCalculate"/>

    <Label fx:id="itemTotalLabel" text="Item Total"/>
    <Label fx:id="itemTotalResultLabel" text="0.0"/>

    <Label fx:id="totalLabel" text="Cart Total"/>
    <Label fx:id="totalResultLabel" text="0.0"/>
</VBox>